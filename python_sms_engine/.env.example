# Python SMS Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# -----------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------
# Shared secret between Laravel and this engine.
# Must match SMS_PYTHON_API_TOKEN in Laravel's .env.
# Leave empty to disable auth (local dev only).
SMS_PYTHON_API_TOKEN=your_token_here

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
SMS_ENGINE_HOST=0.0.0.0
SMS_ENGINE_PORT=9000

# -----------------------------------------------------------------------
# Serial / modem timeouts
# -----------------------------------------------------------------------
# SMS_ENGINE_SERIAL_TIMEOUT — how long each ser.read(256) blocks waiting for data.
#
#   0.2  (recommended) — reads check every 200ms; catches modem responses as soon
#        as they arrive. Measured result: send total_ms ~800ms-1.2s.
#
#   3    (old default) — reads block for 3s before retrying; responses arrive just
#        after the window closes, adding one full 3s miss per phase. Result: ~6s
#        per send even with a healthy persistent connection.
#
#   Do NOT go below 0.1 — too short causes excessive read() syscalls with no gain.
SMS_ENGINE_SERIAL_TIMEOUT=0.2
SMS_ENGINE_COMMAND_TIMEOUT=10
SMS_ENGINE_SEND_TIMEOUT=30

# -----------------------------------------------------------------------
# Inbound SMS (customer replies)
# -----------------------------------------------------------------------
# Laravel endpoint that receives inbound SMS notifications.
# Leave empty to disable inbound delivery (messages still spooled locally).
SMS_ENGINE_INBOUND_WEBHOOK_URL=http://127.0.0.1:8081/api/gateway/inbound

# Max delivery attempts before a spooled message is abandoned.
SMS_ENGINE_INBOUND_RETRY_MAX=10

# -----------------------------------------------------------------------
# Send performance
# -----------------------------------------------------------------------
# Fast send path: skips ATZ reset and uses blocking _read_until() instead
# of the legacy polling loop. Set to false to revert to legacy behaviour.
FAST_SEND_FLOW=true
