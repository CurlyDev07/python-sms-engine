# Python SMS Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# -----------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------
# Shared secret between Laravel and this engine.
# Must match SMS_PYTHON_API_TOKEN in Laravel's .env.
# Leave empty to disable auth (local dev only).
SMS_PYTHON_API_TOKEN=your_token_here

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
SMS_ENGINE_HOST=0.0.0.0
SMS_ENGINE_PORT=9000

# -----------------------------------------------------------------------
# Serial / modem timeouts
# -----------------------------------------------------------------------
SMS_ENGINE_SERIAL_TIMEOUT=3
SMS_ENGINE_COMMAND_TIMEOUT=10
SMS_ENGINE_SEND_TIMEOUT=30

# -----------------------------------------------------------------------
# Inbound SMS (customer replies)
# -----------------------------------------------------------------------
# Laravel endpoint that receives inbound SMS notifications.
# Leave empty to disable inbound delivery (messages still spooled locally).
SMS_ENGINE_INBOUND_WEBHOOK_URL=http://127.0.0.1:8081/api/gateway/inbound

# Max delivery attempts before a spooled message is abandoned.
SMS_ENGINE_INBOUND_RETRY_MAX=10
